/* pages/history/history.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  gap: 16rpx;
}

.filter-item {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.filter-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
}

/* 历史列表 */
.history-list {
  padding: 20rpx 30rpx;
}

.history-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-type {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.item-type.copywriting {
  background: #E3F2FD;
  color: #1976D2;
}

.item-type.cover {
  background: #FFF3E0;
  color: #FF9800;
}

.item-type.both {
  background: #FCE4EC;
  color: #E91E63;
}

.item-time {
  font-size: 22rpx;
  color: #999;
}

.item-content {
  margin-bottom: 16rpx;
}

.item-input {
  margin-bottom: 16rpx;
}

.input-label {
  font-size: 24rpx;
  color: #999;
}

.input-text {
  font-size: 26rpx;
  color: #333;
}

.preview-title {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.title-icon {
  font-size: 24rpx;
  margin-right: 10rpx;
}

.title-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.preview-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  background: #f5f5f5;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #666;
}

.item-cover {
  margin-top: 16rpx;
}

.cover-placeholder {
  background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
  border-radius: 12rpx;
  padding: 40rpx;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

/* 操作按钮 */
.item-actions {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  font-size: 24rpx;
  color: #666;
}

.action-btn.delete {
  color: #F44336;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 50rpx;
}

.empty-icon {
  font-size: 150rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  border: none;
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 107, 0.3);
}

.empty-btn::after {
  border: none;
}

/* 清空按钮 */
.clear-section {
  padding: 30rpx;
}

.clear-btn {
  text-align: center;
  padding: 24rpx;
  color: #F44336;
  font-size: 26rpx;
}

.bottom-space {
  height: 120rpx;
}
