/* pages/generate/generate.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 类型选择 */
.type-tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f8f8;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
}

.tab-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.tab-text {
  font-size: 26rpx;
  font-weight: bold;
}

/* 输入区域 */
.input-section {
  padding: 30rpx;
}

.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.hint {
  font-size: 24rpx;
  color: #999;
}

.input-area {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  font-size: 28rpx;
  line-height: 1.8;
  min-height: 200rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #f0f0f0;
}

.input-area.cover-mode {
  min-height: 150rpx;
}

.input-footer {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.char-count {
  font-size: 24rpx;
  color: #ccc;
}

/* 示例 */
.examples {
  margin-top: 24rpx;
}

.examples-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.examples-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.example-item {
  background: #fff;
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

/* 风格选择 */
.style-section {
  padding: 0 30rpx 30rpx;
}

.style-scroll {
  white-space: nowrap;
}

.style-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 10rpx 0;
}

.style-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  border: 2rpx solid #f0f0f0;
  min-width: 140rpx;
  transition: all 0.3s;
}

.style-item.active {
  border-color: #FF6B6B;
  background: #FFF5F5;
}

.style-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.style-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.style-desc {
  font-size: 20rpx;
  color: #999;
}

/* 封面风格 */
.cover-style-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}

.cover-style-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  padding: 20rpx 10rpx;
  border-radius: 16rpx;
  border: 2rpx solid #f0f0f0;
  transition: all 0.3s;
}

.cover-style-item.active {
  border-color: #FF6B6B;
  background: #FFF5F5;
}

.cover-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.cover-preview.简约风 {
  background: linear-gradient(135deg, #fff 0%, #f0f0f0 100%);
}

.cover-preview.高级感 {
  background: linear-gradient(135deg, #1A1A2E 0%, #333 100%);
}

.cover-preview.可爱风 {
  background: linear-gradient(135deg, #FFE5EC 0%, #FFB6C1 100%);
}

.cover-preview.时尚感 {
  background: linear-gradient(135deg, #2D2D2D 0%, #444 100%);
}

.preview-icon {
  font-size: 32rpx;
}

.cover-style-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.cover-style-desc {
  font-size: 20rpx;
  color: #999;
}

/* 生成按钮 */
.action-section {
  padding: 30rpx;
}

.generate-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 50rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 107, 0.4);
  border: none;
}

.generate-btn::after {
  border: none;
}

.generate-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}

.btn-content {
  display: flex;
  align-items: center;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.btn-loading {
  display: flex;
  align-items: center;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  margin-right: 16rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #fff;
}

.free-tip {
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.free-tip .highlight {
  color: #FF6B6B;
  font-weight: bold;
}

.vip-tip {
  text-align: center;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #FF6B6B;
}

.vip-badge {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: bold;
}

/* 合规检测 */
.compliance-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin: 0 30rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.compliance-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.compliance-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.compliance-badge {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.compliance-badge.low,
.compliance-badge.passed {
  background: #E8F5E9;
  color: #4CAF50;
}

.compliance-badge.medium {
  background: #FFF3E0;
  color: #FF9800;
}

.compliance-badge.high {
  background: #FFEBEE;
  color: #F44336;
}

.sensitive-words {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.sensitive-word {
  background: #FFEBEE;
  color: #F44336;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

/* 结果区域 */
.result-section {
  padding: 0 30rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.result-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  background: #f5f5f5;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.result-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 标题列表 */
.titles-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.title-item {
  background: #f8f8f8;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.title-item.primary {
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE5E5 100%);
  border-left: 6rpx solid #FF6B6B;
}

/* 内容块 */
.result-block {
  margin-bottom: 30rpx;
}

.result-block:last-child {
  margin-bottom: 0;
}

.block-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.block-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.block-action {
  font-size: 22rpx;
  color: #FF6B6B;
}

.block-content {
  background: #f8f8f8;
  padding: 24rpx;
  border-radius: 16rpx;
}

.content-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 标签 */
.tags-content {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  background: linear-gradient(135deg, #FF6B6B20 0%, #FF8E5320 100%);
  color: #FF6B6B;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

/* 封面结果 */
.cover-result {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.cover-wrapper {
  display: flex;
  justify-content: center;
  margin: 20rpx 0;
}

.cover-demo {
  width: 300rpx;
  height: 400rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.cover-demo.简约风 {
  background: linear-gradient(135deg, #fff 0%, #f5f5f5 100%);
  border: 2rpx solid #e0e0e0;
}

.cover-demo.高级感 {
  background: linear-gradient(135deg, #1A1A2E 0%, #333 100%);
}

.cover-demo.可爱风 {
  background: linear-gradient(135deg, #FFE5EC 0%, #FFB6C1 100%);
}

.cover-demo.时尚感 {
  background: linear-gradient(135deg, #2D2D2D 0%, #444 100%);
}

.cover-demo-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.cover-demo.简约风 .cover-demo-icon,
.cover-demo.高级感 .cover-demo-icon,
.cover-demo.时尚感 .cover-demo-icon {
  color: #fff;
}

.cover-demo-text {
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}

.cover-demo.简约风 .cover-demo-text {
  color: #333;
}

.cover-demo.高级感 .cover-demo-text,
.cover-demo.时尚感 .cover-demo-text,
.cover-demo.可爱风 .cover-demo-text {
  color: #333;
}

.cover-demo.高级感 .cover-demo-text,
.cover-demo.时尚感 .cover-demo-text {
  color: #fff;
}

.cover-demo-brand {
  font-size: 20rpx;
  color: #999;
}

.cover-tip {
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-top: 16rpx;
}

.bottom-space {
  height: 150rpx;
}
