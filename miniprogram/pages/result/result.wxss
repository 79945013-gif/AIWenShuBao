/* pages/result/result.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: env(safe-area-inset-bottom);
}

.result-section {
  padding: 20rpx;
}

/* 头部信息 */
.header {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.header-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-type {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.result-type.copywriting {
  background: #E3F2FD;
  color: #1976D2;
}

.result-type.cover {
  background: #FFF3E0;
  color: #FF9800;
}

.result-type.both {
  background: #FCE4EC;
  color: #E91E63;
}

.result-style {
  font-size: 24rpx;
  color: #999;
}

.result-input {
  font-size: 26rpx;
  color: #333;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 107, 0.3);
}

.action-btn.secondary {
  background: #fff;
  color: #666;
}

/* 结果内容 */
.result-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.result-block {
  margin-bottom: 30rpx;
}

.result-block:last-child {
  margin-bottom: 0;
}

.block-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.block-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.block-action {
  font-size: 22rpx;
  color: #FF6B6B;
}

/* 标题列表 */
.titles-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.title-item {
  background: #f8f8f8;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

.title-item.primary {
  background: linear-gradient(135deg, #FFF5F5 0%, #FFE5E5 100%);
  border-left: 6rpx solid #FF6B6B;
}

/* 内容 */
.block-content {
  background: #f8f8f8;
  padding: 24rpx;
  border-radius: 16rpx;
}

.content-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
}

/* 标签 */
.tags-content {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  background: linear-gradient(135deg, #FF6B6B20 0%, #FF8E5320 100%);
  color: #FF6B6B;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

/* 封面结果 */
.cover-result {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.cover-wrapper {
  margin-top: 16rpx;
}

.cover-image {
  width: 100%;
  border-radius: 16rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 50rpx;
}

.empty-icon {
  font-size: 150rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  border: none;
  padding: 24rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
}

.empty-btn::after {
  border: none;
}
