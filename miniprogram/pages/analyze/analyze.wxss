/* pages/analyze/analyze.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F5F7FF 0%, #FFFFFF 100%);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 标签切换 */
.tabs {
  display: flex;
  background: #fff;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
}

.tab-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: bold;
}

/* 输入区域 */
.input-section {
  padding: 30rpx;
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.url-input-wrapper {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.url-input {
  flex: 1;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 26rpx;
}

.paste-btn {
  background: #f5f5f5;
  padding: 24rpx 30rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666;
}

/* 示例 */
.examples {
  margin-bottom: 30rpx;
}

.examples-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.examples-list {
  display: flex;
  gap: 16rpx;
}

.example-item {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

/* 分析按钮 */
.analyze-btn {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 50rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 107, 0.4);
  border: none;
}

.analyze-btn::after {
  border: none;
}

.analyze-btn[disabled] {
  background: #ccc;
  box-shadow: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.btn-loading {
  display: flex;
  align-items: center;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  margin-right: 16rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #fff;
}

/* 结果区域 */
.result-section {
  padding: 0 30rpx 30rpx;
}

/* 综合评分 */
.overall-card {
  display: flex;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 107, 0.3);
}

.score-circle {
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-right: 30rpx;
}

.score-num {
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
}

.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

.score-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.level-tag {
  display: inline-block;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #fff;
  margin-bottom: 16rpx;
  width: fit-content;
}

.level-tag.A {
  background: #FFD700;
  color: #333;
}

.level-tag.A-plus {
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  color: #333;
}

.summary-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.95);
  line-height: 1.6;
}

/* 分析卡片 */
.analysis-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.analysis-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.score-badge {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.card-content {
  display: flex;
  gap: 30rpx;
  margin-bottom: 20rpx;
}

.analysis-item {
  flex: 1;
  text-align: center;
}

.item-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.item-value {
  display: block;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

/* 内容结构 */
.content-structure {
  margin-bottom: 20rpx;
}

.structure-item {
  margin-bottom: 16rpx;
}

.structure-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.structure-desc {
  font-size: 22rpx;
  color: #999;
}

.structure-score {
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  margin-top: 8rpx;
}

.score-bar {
  height: 100%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 4rpx;
}

/* 话题列表 */
.topics-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.topic-item {
  background: #f5f5f5;
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #666;
}

.hot-topics {
  margin-bottom: 20rpx;
}

.hot-label {
  font-size: 24rpx;
  color: #999;
  margin-right: 12rpx;
}

.hot-item {
  font-size: 24rpx;
  color: #FF6B6B;
  font-weight: bold;
  margin-right: 12rpx;
}

/* 建议 */
.suggestions {
  background: #FFF9F0;
  border-radius: 12rpx;
  padding: 20rpx;
}

.suggestions-title {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  color: #FF9800;
  margin-bottom: 12rpx;
}

.suggestion-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.suggestion-item:last-child {
  margin-bottom: 0;
}

/* 改进建议 */
.improvement-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.improvement-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.improvement-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.improvement-item {
  display: flex;
  align-items: flex-start;
}

.improvement-num {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 50%;
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.improvement-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  box-shadow: 0 8rpx 30rpx rgba(255, 107, 107, 0.3);
}

.action-btn.secondary {
  background: #f5f5f5;
  color: #666;
}

/* 历史模式 */
.history-mode {
  padding: 30rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.history-count {
  font-size: 26rpx;
  color: #999;
}

.clear-btn {
  font-size: 26rpx;
  color: #FF6B6B;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
}

.history-info {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.history-score {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.history-score.high {
  background: #E8F5E9;
  color: #4CAF50;
}

.history-score.mid {
  background: #FFF3E0;
  color: #FF9800;
}

.history-score.low {
  background: #FFEBEE;
  color: #F44336;
}

.history-detail {
  flex: 1;
}

.history-url {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-time {
  font-size: 22rpx;
  color: #999;
}

.history-actions {
  display: flex;
  gap: 24rpx;
}

.action-text {
  font-size: 24rpx;
  color: #FF6B6B;
}

.action-text.delete {
  color: #F44336;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

.bottom-space {
  height: 120rpx;
}
